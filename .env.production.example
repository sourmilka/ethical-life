# BarterPay — Production Environment Variables
# Copy this file to .env and fill in real values

# ── Database (Supabase) ─────────────────────────────────
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Redis (Upstash) ─────────────────────────────────────
REDIS_URL=rediss://default:<password>@<region>.upstash.io:6379

# ── JWT Secrets (auto-generated by Render, or use: openssl rand -base64 32) ──
JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM_SECRET

# ── CORS & Domain ───────────────────────────────────────
CORS_ORIGIN=https://barterpay-dashboard.onrender.com
PLATFORM_DOMAIN=onrender.com

# ── File Storage (Supabase Storage S3) ──────────────────
S3_BUCKET=media
S3_REGION=<supabase-project-region>
S3_ACCESS_KEY=<supabase-s3-access-key>
S3_SECRET_KEY=<supabase-s3-secret-key>
S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
S3_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/media

# ── Dashboard Build ─────────────────────────────────────
VITE_API_URL=https://barterpay-server.onrender.com/api
