# BarterPay Server — Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/barterpay

# Redis
REDIS_URL=redis://localhost:6379

# JWT secrets (change these in production!)
JWT_ACCESS_SECRET=change-me-to-a-random-32-char-secret-key-at-least
JWT_REFRESH_SECRET=change-me-to-another-random-32-char-secret-key!!

# CORS — dashboard URL
CORS_ORIGIN=http://localhost:5173

# Platform domain
PLATFORM_DOMAIN=localhost
