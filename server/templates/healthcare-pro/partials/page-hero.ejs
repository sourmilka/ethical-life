<!-- Page Hero (used on inner pages) -->
<section class="page-hero">
    <div class="page-hero-inner">
        <nav class="page-hero-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a> <span>/</span> <span><%= locals.pageHeroTitle || (page && page.title) || '' %></span>
        </nav>
        <h1><%= locals.pageHeroTitle || (page && page.title) || '' %></h1>
        <% if (locals.pageHeroDesc || (page && page.metaDescription)) { %>
        <p><%= locals.pageHeroDesc || page.metaDescription %></p>
        <% } %>
    </div>
</section>
