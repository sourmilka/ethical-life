<!-- Page Hero (used on inner pages) -->
<section class="page-hero">
    <div class="page-hero-content">
        <h1 class="page-hero-title"><%= locals.pageHeroTitle || (page && page.title) || '' %></h1>
        <% if (locals.pageHeroDesc || (page && page.metaDescription)) { %>
        <p class="page-hero-desc"><%= locals.pageHeroDesc || page.metaDescription %></p>
        <% } %>
    </div>
</section>
