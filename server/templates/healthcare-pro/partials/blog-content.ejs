<!-- Blog — Content Section -->
<section class="blog-section">
    <% if (locals.featuredPost) { %>
    <!-- Featured Post -->
    <div class="blog-featured">
        <div class="blog-featured-img">
            <% if (featuredPost.coverImageUrl) { %>
            <img src="<%= featuredPost.coverImageUrl %>" alt="<%= featuredPost.title %>">
            <% } %>
        </div>
        <div class="blog-featured-body">
            <span class="blog-tag">Featured</span>
            <h2><%= featuredPost.title %></h2>
            <p><%= featuredPost.excerpt || '' %></p>
            <div class="blog-meta">
                <span><%= featuredPost.authorName || '' %></span>
                <% if (featuredPost.publishedAt) { %>
                <span><%= new Date(featuredPost.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                <% } %>
                <% if (featuredPost.readTime) { %>
                <span><%= featuredPost.readTime %></span>
                <% } %>
            </div>
            <a href="/pages/blog/<%= featuredPost.slug %>" class="blog-read-more">Read Article &rarr;</a>
        </div>
    </div>
    <% } %>

    <!-- Blog Grid -->
    <div class="blog-grid">
        <% blogPosts.forEach(function(post) { %>
        <a href="/pages/blog/<%= post.slug %>" class="blog-card">
            <div class="blog-card-img">
                <% if (post.coverImageUrl) { %>
                <img src="<%= post.coverImageUrl %>" alt="<%= post.title %>">
                <% } %>
            </div>
            <div class="blog-card-body">
                <% if (post.category) { %>
                <span class="blog-tag"><%= post.category.name %></span>
                <% } %>
                <h3><%= post.title %></h3>
                <p><%= post.excerpt || '' %></p>
                <div class="blog-meta">
                    <span><%= post.authorName || '' %></span>
                    <% if (post.publishedAt) { %>
                    <span><%= new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                    <% } %>
                </div>
            </div>
        </a>
        <% }); %>
    </div>
</section>
