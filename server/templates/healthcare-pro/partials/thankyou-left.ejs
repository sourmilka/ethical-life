<!-- Thank You Page — Left Panel -->
<div class="form-left">
    <a href="/" class="form-logo">
        <% if (settings && settings.logoUrl) { %>
        <img src="<%= settings.logoUrl %>" alt="<%= settings.companyName || '' %>">
        <% } %>
    </a>

    <div class="form-left-body">
        <h1 class="form-left-title">You're all set</h1>
        <p class="form-left-desc">Your intake and payment have been received. A licensed clinician will review your information and may recommend personalized treatment options.</p>
        <p class="form-left-desc">You'll receive an email confirmation shortly with your next steps.</p>
    </div>

    <p class="form-left-footer"><a href="/">&larr; Back to <%= (settings && settings.companyName) || 'Home' %></a></p>
</div>
