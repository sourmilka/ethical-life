<!-- FAQ — Standalone Page Content -->
<section class="faq-page-section">
    <% if (faqGroups && Object.keys(faqGroups).length > 0) { %>
        <% Object.keys(faqGroups).forEach(function(category) { %>
        <div class="faq-category">
            <h2 class="faq-category-title"><%= category %></h2>

            <% faqGroups[category].forEach(function(item) { %>
            <div class="faq-item">
                <button class="faq-question" aria-expanded="false">
                    <span><%= item.question %></span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer">
                    <p><%- item.answer %></p>
                </div>
            </div>
            <% }); %>
        </div>
        <% }); %>
    <% } else if (faqs && faqs.length > 0) { %>
        <% faqs.forEach(function(item) { %>
        <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
                <span><%= item.question %></span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p><%- item.answer %></p>
            </div>
        </div>
        <% }); %>
    <% } else { %>
        <p>No FAQs available at this time.</p>
    <% } %>
</section>

<!-- FAQ — Still have questions CTA -->
<div class="faq-page-contact">
    <h2>Still have questions?</h2>
    <p>Our team is here to help. Get in touch and we&rsquo;ll respond within 24 hours.</p>
    <a href="/pages/contact.html" class="contact-link">Contact Us</a>
</div>
