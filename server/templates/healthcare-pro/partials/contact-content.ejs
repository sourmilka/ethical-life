<!-- Contact — Content Section -->
<section class="contact-section">
    <div class="contact-form-wrapper">
        <h2>Get in Touch</h2>
        <p>Have questions or want to learn more? Send us a message and we'll get back to you.</p>
        <form class="contact-form" data-action="/api/public/contact">
            <div class="form-row">
                <div class="form-group">
                    <label for="contact-name">Full Name</label>
                    <input type="text" id="contact-name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="contact-email">Email</label>
                    <input type="email" id="contact-email" name="email" required>
                </div>
            </div>
            <div class="form-group">
                <label for="contact-subject">Subject</label>
                <input type="text" id="contact-subject" name="subject">
            </div>
            <div class="form-group">
                <label for="contact-message">Message</label>
                <textarea id="contact-message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
    </div>

    <div class="contact-info">
        <% if (settings) { %>
        <div class="contact-cards">
            <% if (settings.contactEmail) { %>
            <div class="contact-card">
                <span class="contact-card-icon">✉</span>
                <h4>Email</h4>
                <p><a href="mailto:<%= settings.contactEmail %>"><%= settings.contactEmail %></a></p>
            </div>
            <% } %>
            <% if (settings.contactPhone) { %>
            <div class="contact-card">
                <span class="contact-card-icon">☎</span>
                <h4>Phone</h4>
                <p><a href="tel:<%= settings.contactPhone %>"><%= settings.contactPhone %></a></p>
            </div>
            <% } %>
            <% if (settings.contactAddress) { %>
            <div class="contact-card">
                <span class="contact-card-icon">📍</span>
                <h4>Address</h4>
                <p><%= settings.contactAddress %></p>
            </div>
            <% } %>
        </div>
        <% } %>
    </div>
</section>
